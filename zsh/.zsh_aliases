# ------------------------------------------------------------
# ALIASES

# dir aliases
alias home="cd ~"
alias dev="cd ~/dev"
alias ah="cd ~/dev/adhoc"
alias dot="cd ~/dev/dotfiles"

# git aliases
alias gs="git status"
alias gb="git branch"
alias ga="git add"
alias gco="git checkout"
alias gp="git pull"

# ls aliases (base 'ls' color is set per-OS in .zshrc)
alias ll="ls -alF"
alias la="ls -A"
alias l="ls -CF"

# python aliases
alias pip-clear="pip freeze | xargs pip uninstall -y"

# misc aliases
alias cl="clear"
alias ps="ps aux"
alias ports="sudo lsof -i -P -n"
alias listen="sudo lsof -i -P -n | grep LISTEN"

# top processes by memory. 'command ps' avoids re-expanding the 'ps'='ps aux' alias;
# GNU (Linux) and BSD (macOS) ps take different flags for the same result.
if [[ "$OSTYPE" == darwin* ]]; then
  alias psmem="command ps -A -o pid,ppid,comm,%mem,%cpu -m | head -n 15"
else
  alias psmem="command ps -eo pid,ppid,cmd,%mem,%cpu --sort=-%mem | head -n 15"
fi

# obsidian aliases
if [[ "$OSTYPE" == darwin* ]]; then
  alias ob="open -a Obsidian"
else
  alias ob="obsidian"
fi
